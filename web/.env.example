# --- Supabase (PostgreSQL) via Prisma ---
# The schema reads APP_DATABASE_URL / APP_DIRECT_URL (not DATABASE_URL) so a host's
# own DATABASE_URL can't override the app's connection.
# Always use the POOLER host (aws-*.pooler.supabase.com) — the direct
# db.<ref>.supabase.co host is IPv6-only and unreachable from IPv4 serverless
# platforms like Vercel. Port 6543 (?pgbouncer=true) for the app, 5432 for migrations.
APP_DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
APP_DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres"

# Secret used to sign session JWTs. Use a long random string (openssl rand -hex 32).
JWT_SECRET="change-me-to-a-long-random-string"

# --- Optional: Razorpay (subscriptions/payments) ---
# Leave blank to run without payments (create-order returns 503).
RAZORPAY_KEY=""
RAZORPAY_SECRET=""
