# --- Supabase (PostgreSQL) via Prisma ---
# Supabase → Project Settings → Database.
# Use the POOLED connection string (port 6543, ?pgbouncer=true) for the app, and
# the DIRECT connection (port 5432) for migrations.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:<password>@db.vbbyztwglyzozoplmweh.supabase.co:5432/postgres"

# Secret used to sign session JWTs. Use a long random string (openssl rand -hex 32).
JWT_SECRET="change-me-to-a-long-random-string"

# --- Optional: Razorpay (subscriptions/payments) ---
# Leave blank to run without payments (create-order returns 503).
RAZORPAY_KEY=""
RAZORPAY_SECRET=""
