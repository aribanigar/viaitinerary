{
  "name": "viaitinerary-web",
  "version": "0.1.0",
  "private": true,
  "description": "ViaItinerary — Next.js port (one app: UI + API) on Supabase/Postgres via Prisma.",
  "scripts": {
    "dev": "next dev",
    "build": "npm --prefix ../frontend install && npm --prefix ../frontend run build && prisma generate && next build",
    "build:next": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "next": "14.2.35",
    "nodemailer": "^6.9.16",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.35",
    "prisma": "^5.22.0"
  }
}
