// ViaItinerary — Prisma schema (Supabase / PostgreSQL)
// Ported from the Laravel models. JSON columns hold the same array/object data
// the original casts produced.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 Int       @id @default(autoincrement())
  name               String
  email              String    @unique
  password           String
  role               String    @default("admin") // super_admin | admin | team
  status             String    @default("active")
  profilePicture     String?   @map("profile_picture")
  embedToken         String?   @map("embed_token")
  bypassSubscription Boolean   @default(false) @map("bypass_subscription")
  emailVerifiedAt    DateTime? @map("email_verified_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  membershipTeam Team?  @relation("TeamMember", fields: [teamId], references: [id])
  teamId         Int?   @map("team_id")
  ownedTeams     Team[] @relation("TeamOwner")
  authoredPosts  BlogPost[] @relation("PostAuthor")

  @@index([role])
  @@index([teamId])
  @@map("users")
}

model Team {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String?  @unique
  isActive  Boolean  @default(true) @map("is_active")
  isPaid    Boolean  @default(false) @map("is_paid")
  ownerId   Int?     @map("created_by")
  owner     User?    @relation("TeamOwner", fields: [ownerId], references: [id])
  members   User[]   @relation("TeamMember")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  blogPosts      BlogPost[]
  blogCategories BlogCategory[]
  blogTags       BlogTag[]

  @@index([ownerId])
  @@map("teams")
}

model Trip {
  id              Int       @id @default(autoincrement())
  userId          Int       @map("user_id")
  teamId          Int?      @map("team_id")
  tripId          String    @unique @map("trip_id")
  tripTitle       String    @map("trip_title")
  destination     String?
  destinationId   Int?      @map("destination_id")
  clientName      String?   @map("client_name")
  clientPhone     String?   @map("client_phone")
  clientEmail     String?   @map("client_email")
  adults          Int       @default(2)
  kidsCnb         Int       @default(0) @map("kids_cnb")
  kids5to12       Int       @default(0) @map("kids_5_to_12")
  startDate       DateTime? @map("start_date")
  duration        String?
  cost            Decimal?  @db.Decimal(12, 2)
  gstAmount       Decimal   @default(0) @map("gst_amount") @db.Decimal(12, 2)
  paidAmount      Decimal   @default(0) @map("paid_amount") @db.Decimal(12, 2)
  refundedAmount  Decimal   @default(0) @map("refunded_amount") @db.Decimal(12, 2)
  currency        String    @default("INR (Rs)")
  imagePath       String?   @map("image_path")
  status          String    @default("pending")
  template        String?   @default("ModernTemplate")
  slug            String?
  includeGst      Boolean   @default(true) @map("include_gst")
  useFlight       Boolean   @default(false) @map("use_flight")
  tagline         String?
  inclusions      Json?
  exclusions      Json?
  otherCosts      Json?     @map("other_costs")
  transportDetails Json?    @map("transport_details")
  followUpSent    Boolean   @default(false) @map("follow_up_sent")
  confirmationSent Boolean  @default(false) @map("confirmation_sent")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  itineraries     Itinerary[]
  accommodations  Accommodation[]
  transportations Transportation[]
  destinationRef  Destination? @relation(fields: [destinationId], references: [id])
  obligations     AccountingObligation[]
  settlements     AccountingSettlement[]

  @@index([userId])
  @@index([teamId])
  @@index([status])
  @@map("trips")
}

model Itinerary {
  id          Int      @id @default(autoincrement())
  tripId      Int      @map("trip_id")
  dayNumber   Int?     @map("day_number")
  title       String?
  location    String?
  description String?
  imagePath   String?  @map("image_path")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@map("itineraries")
}

model Accommodation {
  id                    Int       @id @default(autoincrement())
  tripId                Int       @map("trip_id")
  hotelId               Int?      @map("hotel_id")
  name                  String
  city                  String?
  category              String?
  rooms                 String?
  beds                  Int?      @default(0)
  cnbCount              Int       @default(0) @map("cnb_count")
  extraBeds5To12Count   Int       @default(0) @map("extra_beds_5_to_12_count")
  extraBedsAbove12Count Int       @default(0) @map("extra_beds_above_12_count")
  mealPlan              String?   @map("meal_plan")
  roomType              String?   @default("Deluxe") @map("room_type")
  checkIn               DateTime? @map("check_in")
  checkOut              DateTime? @map("check_out")
  pricePerRoom          Decimal?  @map("price_per_room") @db.Decimal(12, 2)
  bedPrices             Json?     @map("bed_prices")
  imagePath             String?   @map("image_path")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  trip  Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  hotel Hotel? @relation(fields: [hotelId], references: [id])

  @@index([tripId])
  @@map("accommodations")
}

model Transportation {
  id          Int       @id @default(autoincrement())
  tripId      Int       @map("trip_id")
  vehicleId   Int?      @map("vehicle_id")
  tripType    String?   @map("trip_type")
  destination String?
  route       String?
  date        DateTime?
  vehicleType String?   @map("vehicle_type")
  quantity    Int       @default(1)
  remarks     String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  trip    Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])

  @@index([tripId])
  @@map("transportations")
}

model Destination {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  name      String
  activities Json?
  imagePath String?  @map("image_path")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  trips Trip[]

  @@index([userId])
  @@map("destinations")
}

model Hotel {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  name          String
  city          String?
  email         String?
  phone         String?
  priceSections Json?    @map("price_sections")
  imagePath     String?  @map("image_path")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  accommodations Accommodation[]

  @@index([userId])
  @@map("hotels")
}

model Vehicle {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  name      String
  email     String?
  phone     String?
  price     Decimal? @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  transportations Transportation[]

  @@index([userId])
  @@map("vehicles")
}

model InclusionExclusion {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  type      String // inclusion | exclusion
  content   String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("inclusion_exclusions")
}

model AgencySetting {
  id                   Int      @id @default(autoincrement())
  userId               Int      @unique @map("user_id")
  agencyName           String?  @map("agency_name")
  contactPhone         String?  @map("contact_phone")
  contactEmail         String?  @map("contact_email")
  whatsapp             String?
  website              String?
  companyAddress       String?  @map("company_address")
  brandColor           String?  @map("brand_color")
  secondaryColor       String?  @map("secondary_color")
  fontFamily           String?  @map("font_family")
  logoPath             String?  @map("logo_path")
  tagline                   String?
  greetingMessage           String?  @map("greeting_message")
  confirmationMessage       String?  @map("confirmation_message")
  confirmationPdfMessage    String?  @map("confirmation_pdf_message")
  paymentVoucherEmailMessage String? @map("payment_voucher_email_message")
  invoiceEmailMessage       String?  @map("invoice_email_message")
  confirmationHeroImage     String?  @map("confirmation_hero_image")
  beneficiaryName           String?  @map("beneficiary_name")
  bankName                  String?  @map("bank_name")
  accountNumber             String?  @map("account_number")
  ifscCode                  String?  @map("ifsc_code")
  defaultTripImagePath      String?  @map("default_trip_image_path")
  gstPercentage             Decimal? @map("gst_percentage") @db.Decimal(8, 2)
  profitMarginPercentage    Decimal? @map("profit_margin_percentage") @db.Decimal(8, 2)
  includeGst                Boolean  @default(true) @map("include_gst")
  smtpEmail                 String?  @map("smtp_email")
  smtpHost                  String?  @map("smtp_host")
  smtpPort                  Int?     @map("smtp_port")
  smtpEncryption            String?  @map("smtp_encryption")
  smtpAppPassword           String?  @map("smtp_app_password")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  @@map("agency_settings")
}

model LeadInquiry {
  id                Int       @id @default(autoincrement())
  inquiryId         String    @unique @map("inquiry_id")
  userId            Int?      @map("user_id")
  clientName        String    @map("client_name")
  clientEmail       String?   @map("client_email")
  clientPhone       String?   @map("client_phone")
  destination       String?
  adults            Int       @default(1)
  kidsCnb           Int       @default(0) @map("kids_cnb")
  kids5to12         Int       @default(0) @map("kids_5_to_12")
  startDate         DateTime? @map("start_date")
  duration          String?
  approximateBudget Decimal?  @map("approximate_budget") @db.Decimal(12, 2)
  currency          String?
  specialRequests   String?   @map("special_requests")
  status            String    @default("new")
  sourceUrl         String?   @map("source_url")
  notes             String?
  ipAddress         String?   @map("ip_address")
  isPublic          Boolean   @default(false) @map("is_public")
  assignedTo        Int?      @map("assigned_to")
  externalId        String?   @map("external_id")
  utmSource         String?   @map("utm_source")
  utmMedium         String?   @map("utm_medium")
  utmCampaign       String?   @map("utm_campaign")
  gclid             String?
  fbLeadId          String?   @map("fb_lead_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([assignedTo])
  @@index([status])
  @@map("trip_inquiries")
}

model Plan {
  id              Int       @id @default(autoincrement())
  key             String
  country         String?
  name            String
  price           Decimal   @default(0) @db.Decimal(12, 2)
  originalPrice   Decimal?  @map("original_price") @db.Decimal(12, 2)
  durationMonths  Int       @default(1) @map("duration_months")
  tripLimit       Int?      @map("trip_limit")
  features        Json?
  badgeLabel      String?   @map("badge_label")
  recommended     Boolean   @default(false)
  isActive        Boolean   @default(true) @map("is_active")
  isOffer         Boolean   @default(false) @map("is_offer")
  offerImage      String?   @map("offer_image")
  offerStartsAt   DateTime? @map("offer_starts_at")
  offerExpiresAt  DateTime? @map("offer_expires_at")
  teamMemberLimit Int       @default(0) @map("team_member_limit")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([key])
  @@map("plans")
}

model Subscription {
  id                     Int       @id @default(autoincrement())
  userId                 Int       @unique @map("user_id")
  planKey                String?   @map("plan_key")
  status                 String    @default("pending") // trialing | active | pending
  startsAt               DateTime? @map("starts_at")
  endsAt                 DateTime? @map("ends_at")
  trialEndsAt            DateTime? @map("trial_ends_at")
  trialExpiredNotifiedAt DateTime? @map("trial_expired_notified_at")
  tripLimit              Int?      @map("trip_limit")
  tripsUsed              Int       @default(0) @map("trips_used")
  paidAmount             Decimal?  @map("paid_amount") @db.Decimal(12, 2)
  razorpayPaymentId      String?   @map("razorpay_payment_id")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  @@map("subscriptions")
}

model AccountingObligation {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  teamId         Int?     @map("team_id")
  tripId         Int      @map("trip_id")
  direction      String   // receivable | payable
  partyType      String   @default("manual") @map("party_type") // client | hotel | cab | manual
  partyId        Int?     @map("party_id")
  partyName      String?  @map("party_name")
  sourceType     String   @default("manual_adjustment") @map("source_type") // trip | accommodation | transportation | manual_adjustment
  sourceId       Int?     @map("source_id")
  expectedAmount Decimal  @default(0) @map("expected_amount") @db.Decimal(15, 2)
  settledAmount  Decimal  @default(0) @map("settled_amount") @db.Decimal(15, 2)
  status         String   @default("pending") // pending | partial | settled
  dueDate        DateTime? @map("due_date")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  trip        Trip                   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  settlements AccountingSettlement[]

  @@unique([tripId, direction, sourceType, sourceId], name: "obligation_source")
  @@index([userId, tripId])
  @@index([tripId, direction, partyType])
  @@index([sourceType, sourceId])
  @@map("accounting_obligations")
}

model AccountingSettlement {
  id             Int      @id @default(autoincrement())
  obligationId   Int      @map("obligation_id")
  tripId         Int      @map("trip_id")
  userId         Int      @map("user_id")
  createdBy      Int?     @map("created_by")
  amount         Decimal  @db.Decimal(15, 2)
  settlementType String   @default("payment") @map("settlement_type") // receipt | payment | refund | adjustment
  settlementDate DateTime @map("settlement_date")
  method         String?
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  obligation AccountingObligation @relation(fields: [obligationId], references: [id], onDelete: Cascade)
  trip       Trip                 @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([userId, tripId])
  @@index([obligationId, settlementDate])
  @@map("accounting_settlements")
}

model Policy {
  id                    Int      @id @default(autoincrement())
  userId                Int      @unique @map("user_id")
  termsConditions       Json?    @map("terms_conditions")
  mustHaves             Json?    @map("must_haves")
  rolesResponsibilities Json?    @map("roles_responsibilities")
  cancellationPolicy    Json?    @map("cancellation_policy")
  additionalExpenses    Json?    @map("additional_expenses")
  defaultInclusions     Json?    @map("default_inclusions")
  defaultExclusions     Json?    @map("default_exclusions")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("policies")
}

model DemoRequest {
  id             Int       @id @default(autoincrement())
  name           String
  email          String?
  contactNumber  String?   @map("contact_number")
  inviteGuests   String?   @map("invite_guests")
  companyName    String?   @map("company_name")
  noOfEmployees  String?   @map("no_of_employees")
  agencyType     String?   @map("agency_type")
  destinations   String?
  processes      Json?
  officeLocation String?   @map("office_location")
  referralSource String?   @map("referral_source")
  scheduledAt    DateTime? @map("scheduled_at")
  status         String    @default("pending")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("demo_requests")
}

model BlogCategory {
  id           Int      @id @default(autoincrement())
  teamId       Int      @map("team_id")
  name         String
  slug         String
  description  String?
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  team  Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  posts BlogPost[]

  @@unique([teamId, slug])
  @@index([teamId])
  @@map("blog_categories")
}

model BlogPost {
  id              Int       @id @default(autoincrement())
  teamId          Int       @map("team_id")
  authorId        Int       @map("author_id")
  blogCategoryId  Int?      @map("blog_category_id")
  title           String
  slug            String
  excerpt         String?
  content         String
  featuredImage   String?   @map("featured_image")
  status          String    @default("draft") // draft | published | scheduled | archived
  publishedAt     DateTime? @map("published_at")
  authorName      String?   @map("author_name")
  metaTitle       String?   @map("meta_title")
  metaDescription String?   @map("meta_description")
  ogImage         String?   @map("og_image")
  viewsCount      Int       @default(0) @map("views_count")
  readTimeMinutes Int?      @map("read_time_minutes")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  team     Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  author   User          @relation("PostAuthor", fields: [authorId], references: [id])
  category BlogCategory? @relation(fields: [blogCategoryId], references: [id])
  tags     BlogPostTag[]

  @@unique([teamId, slug])
  @@index([teamId, status, publishedAt])
  @@index([authorId])
  @@map("blog_posts")
}

model BlogTag {
  id        Int      @id @default(autoincrement())
  teamId    Int      @map("team_id")
  name      String
  slug      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  team  Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  posts BlogPostTag[]

  @@unique([teamId, slug])
  @@index([teamId])
  @@map("blog_tags")
}

model BlogPostTag {
  id         Int      @id @default(autoincrement())
  blogPostId Int      @map("blog_post_id")
  blogTagId  Int      @map("blog_tag_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  post BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  tag  BlogTag  @relation(fields: [blogTagId], references: [id], onDelete: Cascade)

  @@unique([blogPostId, blogTagId])
  @@map("blog_post_tag")
}
